{
  "functions": {
    "api/app.py": {
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "builds": [
    { "src": "api/app.py", "use": "@vercel/python" },
    { "src": "frontend/package.json", "use": "@vercel/static-build" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "api/app.py" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
